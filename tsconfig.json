{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "composite": true
  },
  "exclude": ["vitest.config.ts", "examples/**", "e2e/**", "playwright.config.ts"],
  "references": [
    { "path": "packages/core" },
    { "path": "packages/morning" },
    { "path": "packages/cardcom" },
    { "path": "packages/client" },
    { "path": "packages/icount" },
    { "path": "packages/mock-server" }
  ]
}
